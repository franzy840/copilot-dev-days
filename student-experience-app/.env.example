# Copy to .env.local for local `vercel dev` testing.
# In production these are set in the Vercel project's Environment Variables.

# Auto-added by Vercel when you attach a Vercel Postgres database to this project.
POSTGRES_URL=

# Gmail account that sends the admin notifications (franzy840@gmail.com).
GMAIL_USER=franzy840@gmail.com
# 16-character App Password from Google Account > Security > 2-Step Verification > App Passwords.
# NOT your normal Gmail password.
GMAIL_APP_PASSWORD=
